{
  "name": "go-path-jumper",
  "displayName": "Go Path Jumper",
  "publisher": "cr4ne89",
  "repository": {
    "type": "git",
    "url": "https://github.com/cr4ne89/go-path-jumper"
  },
  "description": "Go Path Jumper allows quick navigation to files from paths in Go code.",
  "version": "0.0.10",
  "license": "MIT",
  "engines": {
    "vscode": "1.105.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "images/icon.png",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "goPathJumperReferences",
          "name": "Go Path Jumper"
        }
      ]
    },
    "commands": [
      {
        "command": "go-path-jumper.findFileReferences",
        "title": "GPJ: Find File References",
        "category": "Go Path Jumper"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "go-path-jumper.findFileReferences",
          "when": "editorTextFocus",
          "group": "goPathJumper@0"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Go Path Jumper",
      "properties": {
        "go-path-jumper.settings": {
          "type": "array",
          "description": "設定のリストを指定します。",
          "items": {
            "type": "object",
            "properties": {
              "language": {
                "type": "string",
                "default": "go",
                "description": "ファイルの対象言語を指定します。"
              },
              "basePath": {
                "type": "string",
                "default": "/",
                "description": "ファイルのベースパスを指定します。"
              },
              "fileExtension": {
                "type": "string",
                "default": ".csv",
                "description": "ファイルの拡張子を指定します。"
              },
              "delimiter": {
                "type": "string",
                "default": "/",
                "description": "ファイルパスの区切り文字を設定します。"
              },
              "regexPattern": {
                "type": "string",
                "default": "\".*\"",
                "description": "ファイルパスを検出するための正規表現パターンを指定します。"
              },
              "regexMatchPattern": {
                "type": "string",
                "default": "\"([^\"]+)\"",
                "description": "ファイルパスを抽出するための正規表現パターンを指定します。"
              }
            },
            "required": [
              "language",
              "regexPattern",
              "regexMatchPattern"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/vscode": "1.105.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vscode/vsce": "3.7.1",
    "eslint": "10.0.3",
    "ovsx": "0.10.9",
    "typescript": "5.9.3"
  }
}
